# 🔧 Configuración Local - Infraestructura Caja de Abogados
# Archivo de configuración para instalación en VM local
# Copiar como .env y ajustar valores según tu instalación

# 🗄️ Base de Datos PostgreSQL Local
DATABASE_URL="postgresql://infra_user:infra_password@localhost:5432/infra_caja"

# 🔐 Seguridad JWT
JWT_SECRET="infra_caja_jwt_secret_local_2024_muy_seguro"

# 🌐 Puerto del Backend
PORT=4001

# 📊 Configuración Zabbix (ajustar según tu instalación)
ZABBIX_URL="http://192.168.123.6/zabbix/api_jsonrpc.php"
ZABBIX_USER="Admin"
ZABBIX_PASSWORD="zabbix"

# 🛠️ Entorno
NODE_ENV="production"

# 📁 Directorio de uploads
UPLOADS_DIR="uploads"