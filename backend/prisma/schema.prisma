generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Configuración global de la instalación (no es por cliente). Una sola fila (id=1).
model ConfiguracionSistema {
  id             Int      @id @default(1)
  rrhhHabilitado Boolean  @default(true)

  // Integración Zabbix: un único servidor para toda la instalación (los
  // clientes se distinguen por grupo de hosts, ver Empresa.zabbixGrupo).
  // Password cifrado con el mismo mecanismo AES-256-GCM que usa Credencial
  // (backend/src/utils/crypto.ts).
  zabbixUrl             String?
  zabbixUsuario         String?
  zabbixPasswordCifrada String?
  zabbixIv              String?
  zabbixAuthTag         String?

  updatedAt      DateTime @updatedAt
}

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  permisos    String[]  @default([])
  usuarios    Usuario[]
}

model Usuario {
  id                    Int               @id @default(autoincrement())
  username              String            @unique
  email                 String?           @unique
  password              String
  nombre                String
  rolId                 Int
  activo                Boolean           @default(true)
  creadoEn              DateTime          @default(now())
  departamento          String            @default("Sin asignar")
  alertasLeidas         AlertaStock[]     @relation("UsuarioAlertasLeidas")
  articulosCreados      Articulo[]
  comentarios           Comentario[]
  movimientosAprobados  MovimientoStock[] @relation("UsuarioMovimientosAprobados")
  movimientosRealizados MovimientoStock[] @relation("UsuarioMovimientosRealizados")
  procedimientosCreados Procedimiento[]   @relation("UsuarioProcedimientosCreados")
  productosCreados      ProductoStock[]   @relation("UsuarioProductosCreados")
  relevamientos         Relevamiento[]
  credencialesCreadas   Credencial[]
  accesosCredenciales   CredencialAcceso[]
  reportesGenerados     ReporteStock[]    @relation("UsuarioReportesGenerados")
  tareasCreadas         Tarea[]           @relation("CreadorTarea")
  tareasResponsable     Tarea[]           @relation("Tarea_responsable")
  rol                   Rol               @relation(fields: [rolId], references: [id])
  decisiones            Vacacion[]        @relation("Decisiones")
}

// ===== MULTI-CLIENTE =====
// Una Empresa = un cliente de la empresa de IT. Los módulos de infraestructura
// (CMDB, Stock, Tareas, Relevamientos, Procedimientos, KB) se etiquetan por Empresa.
// RRHH y Usuario/Rol quedan globales: son del personal propio de la empresa de IT.
model Empresa {
  id                 String   @id @default(cuid())
  nombre             String   @unique
  descripcion        String?
  activo             Boolean  @default(true)
  // Módulos multi-cliente visibles/habilitados para este cliente.
  // Claves válidas: cmdb, stock, tareas, relevamientos, procedimientos, kb
  modulosHabilitados String[] @default(["cmdb", "stock", "tareas", "relevamientos", "procedimientos", "kb"])

  // Grupo de hosts en Zabbix que identifica a este cliente. Las credenciales
  // de Zabbix son únicas para toda la instalación (ConfiguracionSistema);
  // cada cliente solo filtra por su grupo dentro de ese mismo servidor.
  zabbixGrupo String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  relevamientos     Relevamiento[]
  procedimientos    Procedimiento[]
  categoriasTarea   CategoriaTarea[]
  tareas            Tarea[]
  categoriasKb      Categoria[]
  articulos         Articulo[]
  categoriasStock   CategoriaStock[]
  unidadesMedida    UnidadMedida[]
  proveedoresStock  ProveedorStock[]
  ubicacionesStock  UbicacionStock[]
  productosStock    ProductoStock[]
  tiposMovimiento   TipoMovimiento[]
  movimientosStock  MovimientoStock[]
  alertasStock      AlertaStock[]
  reportesStock     ReporteStock[]
  servidoresFisicos ServidorFisico[]
  maquinasVirtuales MaquinaVirtual[]
  equiposRed        EquipoRed[]
  equiposUsuario    EquipoUsuario[]
  servicios         Servicio[]
  credenciales      Credencial[]

  @@index([nombre])
}

model Relevamiento {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  responsable   String
  ubicacion     String
  observaciones String?
  usuarioId     Int
  empresaId     String
  creadoEn      DateTime @default(now())
  items         Item[]
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  empresa       Empresa  @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model Item {
  id             Int          @id @default(autoincrement())
  tipo           String
  marca          String
  modelo         String
  serie          String
  estado         String
  observaciones  String?
  relevamientoId Int
  relevamiento   Relevamiento @relation(fields: [relevamientoId], references: [id], onDelete: Cascade)
}

model Procedimiento {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String
  adjuntos    String[]
  creadoPorId Int
  empresaId   String
  creadoEn    DateTime @default(now())
  creadoPor   Usuario  @relation("UsuarioProcedimientosCreados", fields: [creadoPorId], references: [id])
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  tareas      Tarea[]

  @@index([empresaId])
}

model CategoriaTarea {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  color       String?
  icono       String?
  activa      Boolean  @default(true)
  empresaId   String
  creadoEn    DateTime @default(now())
  tareas      Tarea[]
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
}

model Tarea {
  id               Int             @id @default(autoincrement())
  titulo           String
  descripcion      String?
  responsableId    Int?
  estado           String          @default("pendiente")
  prioridad        String          @default("media")
  categoria        String          @default("infraestructura")
  origen           String          @default("interno")
  impacto          String          @default("individual")
  tipo             String
  periodo          String
  repeticion       String
  intervalo        Int?
  diaDelMes        String?
  fechaVencimiento DateTime?
  fechaCierre      DateTime?
  observaciones    String?
  solicitante      String?
  activoRelacionado String?
  empresaId        String
  creadaPorId      Int
  creadaEn         DateTime        @default(now())
  actualizadaEn    DateTime        @updatedAt
  finalizadaEn     DateTime?
  procedimientoId  Int?
  categoriaId      Int?
  comentarios      Comentario[]
  categoriaRef     CategoriaTarea? @relation(fields: [categoriaId], references: [id])
  creadaPor        Usuario         @relation("CreadorTarea", fields: [creadaPorId], references: [id])
  procedimiento    Procedimiento?  @relation(fields: [procedimientoId], references: [id])
  responsable      Usuario?        @relation("Tarea_responsable", fields: [responsableId], references: [id])
  empresa          Empresa         @relation(fields: [empresaId], references: [id])

  @@index([estado])
  @@index([prioridad])
  @@index([categoria])
  @@index([responsableId])
  @@index([fechaVencimiento])
  @@index([fechaCierre])
  @@index([empresaId])
}

model Comentario {
  id        Int      @id @default(autoincrement())
  contenido String
  tareaId   Int
  autorId   Int
  creadoEn  DateTime @default(now())
  autor     Usuario  @relation(fields: [autorId], references: [id])
  tarea     Tarea    @relation(fields: [tareaId], references: [id])
}

model Link {
  id       Int      @id @default(autoincrement())
  label    String
  url      String
  creadoEn DateTime @default(now())
}

model Categoria {
  id            Int         @id @default(autoincrement())
  nombre        String
  descripcion   String?
  icono         String?
  padreId       Int?
  empresaId     String
  articulos     Articulo[]
  padre         Categoria?  @relation("CategoriaPadre", fields: [padreId], references: [id])
  subcategorias Categoria[] @relation("CategoriaPadre")
  empresa       Empresa     @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model Articulo {
  id            Int       @id @default(autoincrement())
  titulo        String
  contenido     String
  categoriaId   Int
  adjuntos      String[]
  creadoPorId   Int
  empresaId     String
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime? @updatedAt
  codigo        String?
  version       String?   @default("1.0")
  area          String?
  responsable   String?
  estado        String    @default("Borrador")
  fechaRevision DateTime?
  categoria     Categoria @relation(fields: [categoriaId], references: [id])
  creadoPor     Usuario   @relation(fields: [creadoPorId], references: [id])
  empresa       Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model CategoriaStock {
  id          Int             @id @default(autoincrement())
  nombre      String
  descripcion String?
  icono       String?
  color       String?
  activo      Boolean         @default(true)
  empresaId   String
  creadoEn    DateTime        @default(now())
  productos   ProductoStock[]
  empresa     Empresa         @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
}

model UnidadMedida {
  id          Int             @id @default(autoincrement())
  nombre      String
  abreviacion String
  tipo        String
  activo      Boolean         @default(true)
  empresaId   String
  productos   ProductoStock[]
  empresa     Empresa         @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
  @@unique([empresaId, abreviacion])
}

model ProveedorStock {
  id        Int             @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  direccion String?
  sitioWeb  String?
  activo    Boolean         @default(true)
  empresaId String
  creadoEn  DateTime        @default(now())
  productos ProductoStock[]
  empresa   Empresa         @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
}

model UbicacionStock {
  id                 Int               @id @default(autoincrement())
  nombre             String
  descripcion        String?
  tipo               String?
  activo             Boolean           @default(true)
  empresaId          String
  creadoEn           DateTime          @default(now())
  movimientosDestino MovimientoStock[] @relation("MovimientoDestino")
  movimientosOrigen  MovimientoStock[] @relation("MovimientoOrigen")
  productos          ProductoStock[]
  empresa            Empresa           @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
}

model ProductoStock {
  id                    Int               @id @default(autoincrement())
  codigo                String
  nombre                String
  descripcion           String?
  marca                 String?
  modelo                String?
  numeroSerie           String?
  codigoBarras          String?
  stockActual           Int               @default(0)
  stockMinimo           Int               @default(1)
  stockMaximo           Int?
  precioCompra          Float?
  precioVenta           Float?
  moneda                String            @default("ARS")
  categoriaId           Int
  unidadMedidaId        Int
  proveedorId           Int?
  ubicacionId           Int?
  estado                String            @default("Activo")
  condicion             String            @default("Nuevo")
  fechaCompra           DateTime?
  fechaVencimiento      DateTime?
  fechaUltimoMovimiento DateTime?
  observaciones         String?
  tags                  String[]
  imagenes              String[]
  documentos            String[]
  empresaId             String
  creadoPorId           Int
  creadoEn              DateTime          @default(now())
  actualizadoEn         DateTime          @updatedAt
  alertas               AlertaStock[]
  movimientos           MovimientoStock[]
  categoria             CategoriaStock    @relation(fields: [categoriaId], references: [id])
  creadoPor             Usuario           @relation("UsuarioProductosCreados", fields: [creadoPorId], references: [id])
  proveedor             ProveedorStock?   @relation(fields: [proveedorId], references: [id])
  ubicacion             UbicacionStock?   @relation(fields: [ubicacionId], references: [id])
  unidadMedida          UnidadMedida      @relation(fields: [unidadMedidaId], references: [id])
  empresa               Empresa           @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, codigo])
}

model TipoMovimiento {
  id              Int               @id @default(autoincrement())
  nombre          String
  descripcion     String?
  afectaStock     String
  requiereOrigen  Boolean           @default(false)
  requiereDestino Boolean           @default(false)
  color           String?
  icono           String?
  activo          Boolean           @default(true)
  empresaId       String
  movimientos     MovimientoStock[]
  empresa         Empresa           @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, nombre])
}

model MovimientoStock {
  id               Int             @id @default(autoincrement())
  numero           String
  productoId       Int
  cantidad         Int
  stockAnterior    Int
  stockNuevo       Int
  tipoMovimientoId Int
  origenId         Int?
  destinoId        Int?
  motivo           String?
  observaciones    String?
  numeroFactura    String?
  numeroRemito     String?
  costoUnitario    Float?
  costoTotal       Float?
  empresaId        String
  realizadoPorId   Int
  fechaMovimiento  DateTime        @default(now())
  fechaRegistro    DateTime        @default(now())
  estado           String          @default("Completado")
  aprobadoPorId    Int?
  fechaAprobacion  DateTime?
  entregadoA       String?
  aprobadoPor      Usuario?        @relation("UsuarioMovimientosAprobados", fields: [aprobadoPorId], references: [id])
  destino          UbicacionStock? @relation("MovimientoDestino", fields: [destinoId], references: [id])
  origen           UbicacionStock? @relation("MovimientoOrigen", fields: [origenId], references: [id])
  producto         ProductoStock   @relation(fields: [productoId], references: [id])
  realizadoPor     Usuario         @relation("UsuarioMovimientosRealizados", fields: [realizadoPorId], references: [id])
  tipoMovimiento   TipoMovimiento  @relation(fields: [tipoMovimientoId], references: [id])
  empresa          Empresa         @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@unique([empresaId, numero])
}

model AlertaStock {
  id         Int           @id @default(autoincrement())
  productoId Int
  tipo       String
  mensaje    String
  nivel      String
  activa     Boolean       @default(true)
  leida      Boolean       @default(false)
  empresaId  String
  creadoEn   DateTime      @default(now())
  leidaEn    DateTime?
  leidaPorId Int?
  leidaPor   Usuario?      @relation("UsuarioAlertasLeidas", fields: [leidaPorId], references: [id])
  producto   ProductoStock @relation(fields: [productoId], references: [id])
  empresa    Empresa       @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model ReporteStock {
  id              Int       @id @default(autoincrement())
  nombre          String
  tipo            String
  parametros      Json
  formato         String
  archivo         String?
  estado          String    @default("Generando")
  empresaId       String
  generadoPorId   Int
  fechaGeneracion DateTime  @default(now())
  fechaCompletado DateTime?
  generadoPor     Usuario   @relation("UsuarioReportesGenerados", fields: [generadoPorId], references: [id])
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model Empleado {
  id              String              @id @default(cuid())
  nombre          String
  apellido        String
  dni             String              @unique
  email           String              @unique
  departamento    String
  estado          EstadoEmpleado      @default(ACTIVO)
  fechaIngreso    DateTime
  diasDisponibles Int                 @default(20)
  diasBase2023    Int? // Días disponibles al inicio de 2023 (antes de sumar días por años)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  vacaciones      Vacacion[]
  licencias       Licencia[]
  documentos      DocumentoEmpleado[]
  equiposUsuario  EquipoUsuario[]

  @@index([departamento])
  @@index([estado])
  @@index([email])
}

model Vacacion {
  id                 String         @id @default(cuid())
  empleadoId         String
  fechaInicio        DateTime
  fechaFin           DateTime
  diasSolicitados    Int
  observaciones      String?
  estado             EstadoVacacion @default(PENDIENTE)
  decididoPorId      Int?
  comentarioDecision String?
  decididoEn         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  empleado           Empleado       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  decididoPor        Usuario?       @relation("Decisiones", fields: [decididoPorId], references: [id])

  @@index([estado])
  @@index([fechaInicio, fechaFin])
  @@index([empleadoId])
}

model Licencia {
  id            String   @id @default(cuid())
  empleadoId    String
  tipo          String
  fechaInicio   DateTime
  fechaFin      DateTime
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  empleado      Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
  @@index([fechaInicio, fechaFin])
}

model DocumentoEmpleado {
  id            String         @id @default(cuid())
  empleadoId    String
  nombreArchivo String
  tipoArchivo   TipoDocumento?
  urlArchivo    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  empleado      Empleado       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
  @@index([tipoArchivo])
}

enum EstadoEmpleado {
  ACTIVO
  INACTIVO
}

enum EstadoVacacion {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

enum TipoDocumento {
  DNI
  CONTRATO
  CERTIFICADO_MEDICO
  CERTIFICADO_ESTUDIOS
  OTRO
}

// ===== CMDB / INVENTARIO DE INFRAESTRUCTURA =====

enum EstadoEquipo {
  PRODUCCION
  TEST
  FUERA_DE_SERVICIO
  MANTENIMIENTO
}

enum TipoEquipoRed {
  MIKROTIK
  PFSENSE
  SWITCH
  ACCESS_POINT
  ROUTER
  FIREWALL
  OTRO
}

enum TipoEquipoUsuario {
  PC
  NOTEBOOK
  IMPRESORA
  MONITOR
  TECLADO
  MOUSE
  OTRO
}

enum TipoServicio {
  SQL
  IIS
  ZABBIX
  PROXY
  NTOPNG
  DC
  DNS
  DHCP
  FILE_SERVER
  WEB_SERVER
  MAIL_SERVER
  BACKUP_SERVER
  VEEAM
  VMWARE
  HYPER_V
  WIFI
  OTRO
}

enum TipoEquipoServicio {
  SERVIDOR_FISICO
  MAQUINA_VIRTUAL
}

enum TipoEquipoCredencial {
  SERVIDOR_FISICO
  MAQUINA_VIRTUAL
  EQUIPO_RED
  EQUIPO_USUARIO
  SERVICIO
  EMAIL
  ACCESO_REMOTO
  OTRO
}

// Servidores físicos
model ServidorFisico {
  id               String       @id @default(cuid())
  nombre           String
  ip               String?
  rol              String? // Rol principal del servidor
  ubicacion        String? // Ubicación física
  serie            String?
  garantia         DateTime? // Fecha de vencimiento de garantía
  estado           EstadoEquipo @default(PRODUCCION)
  empresaId        String
  fechaAlta        DateTime     @default(now())
  fechaBaja        DateTime?
  notasTecnicas    String? // Ej: "no apagar", "tiene backup en Veeam"
  procesador       String?
  ram              String?
  almacenamiento   String?
  sistemaOperativo String?
  fabricante       String?
  modelo           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relaciones
  maquinasVirtuales MaquinaVirtual[]
  servicios         Servicio[]       @relation("ServidorFisicoServicios")
  credenciales      Credencial[]
  empresa           Empresa          @relation(fields: [empresaId], references: [id])

  @@index([nombre])
  @@index([ip])
  @@index([estado])
  @@index([serie])
  @@index([empresaId])
  @@unique([empresaId, serie])
}

// Máquinas virtuales
model MaquinaVirtual {
  id               String       @id @default(cuid())
  nombre           String
  ip               String?
  sistemaOperativo String?
  rol              String? // DC, SQL, Zabbix, Proxy, etc.
  estado           EstadoEquipo @default(PRODUCCION)
  empresaId        String
  fechaAlta        DateTime     @default(now())
  fechaBaja        DateTime?
  notasTecnicas    String?
  hostId           String? // Servidor físico donde corre
  vcpu             Int?
  ram              String?
  almacenamiento   String?
  hipervisor       String? // VMware, Hyper-V, etc.
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relaciones
  host         ServidorFisico? @relation(fields: [hostId], references: [id], onDelete: SetNull)
  servicios    Servicio[]      @relation("MaquinaVirtualServicios")
  credenciales Credencial[]
  empresa      Empresa         @relation(fields: [empresaId], references: [id])

  @@index([nombre])
  @@index([ip])
  @@index([estado])
  @@index([hostId])
  @@index([empresaId])
}

// Equipos de red
model EquipoRed {
  id            String        @id @default(cuid())
  nombre        String
  tipo          TipoEquipoRed
  ip            String?
  ubicacion     String?
  serie         String?
  fabricante    String?
  modelo        String?
  estado        EstadoEquipo  @default(PRODUCCION)
  empresaId     String
  fechaAlta     DateTime      @default(now())
  fechaBaja     DateTime?
  notasTecnicas String?
  firmware      String?
  puertos       Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  credenciales Credencial[]
  empresa      Empresa      @relation(fields: [empresaId], references: [id])

  @@index([nombre])
  @@index([ip])
  @@index([tipo])
  @@index([estado])
  @@index([serie])
  @@index([empresaId])
  @@unique([empresaId, serie])
}

// Equipos de usuario
model EquipoUsuario {
  id               String            @id @default(cuid())
  nombre           String
  tipo             TipoEquipoUsuario
  ip               String?
  ubicacion        String?
  serie            String?
  fabricante       String?
  modelo           String?
  estado           EstadoEquipo      @default(PRODUCCION)
  empresaId        String
  fechaAlta        DateTime          @default(now())
  fechaBaja        DateTime?
  notasTecnicas    String?
  sistemaOperativo String?
  usuarioId        String? // Empleado asignado
  area             String? // Área/Departamento
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relaciones
  usuario      Empleado?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  credenciales Credencial[]
  empresa      Empresa      @relation(fields: [empresaId], references: [id])

  @@index([nombre])
  @@index([ip])
  @@index([tipo])
  @@index([estado])
  @@index([usuarioId])
  @@index([area])
  @@index([serie])
  @@index([empresaId])
  @@unique([empresaId, serie])
}

// Servicios que corren en servidores/VMs (o independientes, ej: WiFi)
model Servicio {
  id            String       @id @default(cuid())
  nombre        String
  tipo          TipoServicio
  version       String?
  puerto        Int?
  ssid          String? // Solo para tipo WIFI
  estado        EstadoEquipo @default(PRODUCCION)
  empresaId     String
  fechaAlta     DateTime     @default(now())
  fechaBaja     DateTime?
  notasTecnicas String?

  // Relación opcional con servidor físico o VM (ej: WiFi no está atado a ningún equipo)
  tipoEquipo       TipoEquipoServicio?
  servidorFisicoId String?
  maquinaVirtualId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  servidorFisico ServidorFisico? @relation("ServidorFisicoServicios", fields: [servidorFisicoId], references: [id], onDelete: Cascade)
  maquinaVirtual MaquinaVirtual? @relation("MaquinaVirtualServicios", fields: [maquinaVirtualId], references: [id], onDelete: Cascade)
  credenciales   Credencial[]
  empresa        Empresa         @relation(fields: [empresaId], references: [id])

  @@index([nombre])
  @@index([tipo])
  @@index([estado])
  @@index([servidorFisicoId])
  @@index([maquinaVirtualId])
  @@index([empresaId])
}

// Credenciales cifradas. Pueden asociarse a un equipo/servicio del CMDB, o ser
// standalone (EMAIL, ACCESO_REMOTO, OTRO) para accesos que no pertenecen a ningún equipo.
model Credencial {
  id              String   @id @default(cuid())
  nombre          String // Etiqueta: "Admin local", "Usuario SA", "WiFi Visitas"
  usuario         String?
  passwordCifrada String // Ciphertext base64 (AES-256-GCM)
  iv              String // Base64
  authTag         String // Base64
  url             String? // Webmail, portal de acceso remoto, etc. (solo accesos standalone)
  notas           String?

  tipoEquipo       TipoEquipoCredencial
  servidorFisicoId String?
  maquinaVirtualId String?
  equipoRedId      String?
  equipoUsuarioId  String?
  servicioId       String?
  empresaId        String

  creadoPorId   Int
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Relaciones
  creadoPor      Usuario          @relation(fields: [creadoPorId], references: [id])
  servidorFisico ServidorFisico?  @relation(fields: [servidorFisicoId], references: [id], onDelete: Cascade)
  maquinaVirtual MaquinaVirtual?  @relation(fields: [maquinaVirtualId], references: [id], onDelete: Cascade)
  equipoRed      EquipoRed?       @relation(fields: [equipoRedId], references: [id], onDelete: Cascade)
  equipoUsuario  EquipoUsuario?   @relation(fields: [equipoUsuarioId], references: [id], onDelete: Cascade)
  servicio       Servicio?        @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  accesos        CredencialAcceso[]
  empresa        Empresa          @relation(fields: [empresaId], references: [id])

  @@index([tipoEquipo])
  @@index([servidorFisicoId])
  @@index([maquinaVirtualId])
  @@index([equipoRedId])
  @@index([equipoUsuarioId])
  @@index([servicioId])
  @@index([empresaId])
}

// Auditoría liviana: quién reveló qué contraseña y cuándo
model CredencialAcceso {
  id           String   @id @default(cuid())
  credencialId String
  usuarioId    Int
  fecha        DateTime @default(now())

  credencial Credencial @relation(fields: [credencialId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([credencialId])
}
