# Ejemplo de configuración Nginx para Infra Caja (SPA + API)
# Copiar a /etc/nginx/sites-available/infra-caja y enlazar en sites-enabled.
# IMPORTANTE: Las rutas como /dashboard/relevamientos deben devolver index.html (fallback SPA).

server {
    listen 80;
    server_name intranet.caja-abogados.org.ar 192.168.123.147;

    # Frontend (SPA) - carpeta generada por: cd frontend && npm run build
    root /opt/infra-caja/frontend/dist;
    index index.html;

    # Fallback SPA: cualquier ruta que no sea archivo/carpeta → index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API → backend Node (PM2)
    location /api/ {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Archivos subidos (opcional)
    location /uploads/ {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}
